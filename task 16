interface Animal {
    boolean feed(boolean timeToEat);
    void groom();
    void pet();
    void Danger();
}

public class Gorilla implements Animal {

    @Override
    public boolean feed(boolean timeToEat) {
        // put gorilla food into cage
        System.out.println("Feeding: put gorilla food into cage");
        return timeToEat;
    }

    @Override
    public void groom() {
        // lather, rinse, repeat
        System.out.println("Grooming: lather, rinse, repeat");
    }

    @Override
    public void pet() {
        System.out.println("Petting: pet at your own risk");
    }

    @Override
    public void Danger() {
        System.out.println("Danger: This Animal Can Grab you may risk Injuries");
    }
    public static void main(String[] args) {

        Gorilla myGorilla = new Gorilla();

        myGorilla.feed(true);
        myGorilla.groom();
        myGorilla.pet();
        myGorilla.Danger();
    }
}
